<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ridehailing.mapper.PaymentMapper">

  <resultMap id="paymentResultMap" type="com.ridehailing.model.payment.Payment" autoMapping="false">
    <id property="id" column="id" javaType="java.util.UUID" jdbcType="OTHER"/>
    <result property="tenantId" column="tenant_id" javaType="java.util.UUID" jdbcType="OTHER"/>
    <result property="tripId" column="trip_id" javaType="java.util.UUID" jdbcType="OTHER"/>
    <result property="riderId" column="rider_id" javaType="java.util.UUID" jdbcType="OTHER"/>
    <result property="amount" column="amount"/>
    <result property="currency" column="currency"/>
    <result property="pspReference" column="psp_reference"/>
    <result property="idempotencyKey" column="idempotency_key"/>
    <result property="addDate" column="add_date"/>
    <result property="updateDate" column="update_date"/>
    <result property="deleteInfo" column="delete_info"/>
    <association property="status" javaType="com.ridehailing.model.common.IdName">
      <result property="id" column="status_id"/>
    </association>
    <association property="paymentMethod" javaType="com.ridehailing.model.common.IdName">
      <result property="id" column="payment_method_id"/>
    </association>
  </resultMap>

  <insert id="insert" parameterType="com.ridehailing.model.payment.Payment">
    INSERT INTO payments (tenant_id, trip_id, rider_id, amount, currency, status_id,
      payment_method_id, idempotency_key, add_date)
    VALUES (#{tenantId}, #{tripId}, #{riderId}, #{amount}, #{currency},
      #{status.id}, #{paymentMethod.id}, #{idempotencyKey}, NOW())
  </insert>

  <select id="findById" resultMap="paymentResultMap">
    SELECT * FROM payments WHERE id = #{id} AND delete_info IS NULL
  </select>

  <select id="findByIdempotencyKey" resultMap="paymentResultMap">
    SELECT * FROM payments WHERE idempotency_key = #{idempotencyKey} AND delete_info IS NULL
  </select>

  <update id="updateStatus">
    UPDATE payments
    SET status_id = #{statusId},
      psp_reference = COALESCE(#{pspReference}, psp_reference),
      update_date = NOW()
    WHERE id = #{id} AND delete_info IS NULL
  </update>

</mapper>
